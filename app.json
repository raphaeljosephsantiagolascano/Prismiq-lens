{
  "expo": {
    "name": "Prismiq",
    "slug": "prismiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "prismiq",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/splash.png",
            "backgroundColor": "#0d0f14"
          }
        }
      ],
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Prismiq uses the camera to scan meals, produce, plants and stones."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Prismiq needs access to your photos so you can scan an existing picture."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.prismiq.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.prismiq.app",
      "adaptiveIcon": {
        "backgroundColor": "#1E9B54",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
